Function.prototype.bound = 
function (obj,...initialArgs){
    const originalFn = this;
    return function(...laterArgs){
        obj.newFn = originalFn ;
        return obj.newFn(...initialArgs,...laterArgs)
    }
}

f = fn.bound(obj,'hello')
f('how are you')

