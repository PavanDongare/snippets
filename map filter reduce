/*
map
filter-   cb (e,i,arr) over each, push(e) if cb true
reduce    cb(a,e,i,arr),1 over each, acc = cb
forEach - cb(e,i,ar) over each, no return
*/

Array.prototype.filterNew = function (cb){
     let newArray = [];
     if(Array.isArray(this)){
        this.forEach((x,index,arr)=>{
           if(cb(x,index,arr)==true) newArray.push(x);
        })
        return newArray;
    }
}
