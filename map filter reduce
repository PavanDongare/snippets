Array.prototype.reduceNew = function(cb,initial){
    let acc = initial!=undefined ? initial : 0;
    if(Array.isArray(this)){
        this.forEach((x,index,arr)=>{
           acc =  cb(acc,x,index,arr);
        })
        return acc;
    }
}

